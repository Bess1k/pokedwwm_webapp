<div{{ attributes }}>
    <div class="card" style="width: 18rem;">
        <img src="{{ this.img }}" class="card-img-top" alt="...">
        <div class="card-body">
            <h5 class="card-title">{{ this.title }}</h5>

            {% block content %}{% endblock %}
            
            <twig:BootstrapButton class="mt-2"
                text="{{ this.label }}"
                type="primary" link="{{ this.link }}" />
            
    </div>
</div>
</div>